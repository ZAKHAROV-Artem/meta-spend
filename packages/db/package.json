{
  "name": "@crypto-tracker/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean",
    "dev": "tsup src/index.ts --format cjs --dts --watch",
    "db:generate": "prisma generate",
    "db:reset": "dotenv -e ../../apps/api/.env -- prisma migrate reset",
    "db:migrate": "dotenv -e ../../apps/api/.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../apps/api/.env -- prisma migrate deploy",
    "db:seed": "dotenv -e ../../apps/api/.env -- ts-node --project tsconfig.json prisma/seed.ts",
    "studio": "dotenv -e ../../apps/api/.env -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1"
  },
  "devDependencies": {
    "prisma": "^6.2.1",
    "tsup": "^8.3.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.7",
    "dotenv-cli": "^8.0.0"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.json prisma/seed.ts"
  }
}

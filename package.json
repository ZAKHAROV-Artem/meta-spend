{
  "name": "metaspend",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "reinstall": "pnpm install --force",
    "db:generate": "turbo run db:generate",
    "db:migrate": "pnpm --filter @metaspend/db run db:migrate",
    "db:studio": "pnpm --filter @metaspend/db run studio",
    "db:seed": "pnpm --filter @metaspend/db run db:seed",
    "db:reset": "pnpm --filter @metaspend/db run db:reset",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "prettier": "^3.4.2",
    "eslint": "^9.18.0"
  }
}

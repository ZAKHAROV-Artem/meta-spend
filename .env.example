# Copy to .env and customize for this deployment.
# Local dev works fine without a .env file (defaults below apply).

# Public origin the web app + API are reachable at.
# Local dev: http://localhost:3001 (api) / http://localhost:3000 (web)
# VPS (IP-only): http://<VPS_IP>  -- nginx proxies /api/ on this same origin to the api container
NEXT_PUBLIC_API_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000

# Strong password for the Postgres container - change for any non-local deployment.
POSTGRES_PASSWORD=cft_password

@startuml
skinparam shadowing false
skinparam activity {
  BackgroundColor White
  BorderColor Black
  ArrowColor Black
}

title Diagram czynności - parowanie rozszerzenia Chrome

start

:Użytkownik loguje się\ndo aplikacji web;
:Przechodzi do strony\nUstawienia;
:Kliknięcie "Wygeneruj kod parowania";
:API tworzy tymczasowy\n6-cyfrowy kod;
:Kod zostaje wyświetlony\nw aplikacji web;

:Użytkownik otwiera popup\nrozszerzenia Chrome;
:Wpisuje kod parowania;
:Rozszerzenie wysyła kod\ndo API;

if (Kod poprawny i aktywny?) then (tak)
  :API generuje token\nrozszerzenia;
  :Hash tokenu zapisywany\nw bazie danych;
  :Token zostaje zwrócony\ndo rozszerzenia;
  :Rozszerzenie zapisuje token\nw chrome.storage.local;
  :Wyświetlenie statusu\n"Połączono";
else (nie)
  :Wyświetlenie błędu:\nkod niepoprawny lub wygasł;
endif

stop
@enduml

{
  "name": "@metaspend/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Syncs your MetaMask Card transactions into MetaSpend for spending tracking and analytics.",
  "manifest": {
    "name": "MetaSpend - MetaMask Card sync",
    "action": {
      "default_popup": "popup.html",
      "default_title": "MetaSpend Card"
    },
    "permissions": [
      "storage",
      "tabs",
      "scripting"
    ],
    "host_permissions": [
      "https://portfolio.metamask.io/*",
      "https://card.metamask.io/*",
      "https://metaspend.app/*"
    ]
  },
  "scripts": {
    "dev": "plasmo dev --no-cs-reload",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "plasmo": "^0.90.5",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}

{
  "icons": {
    "16": "./gen-assets/icon16.plasmo.png",
    "32": "./gen-assets/icon32.plasmo.png",
    "48": "./gen-assets/icon48.plasmo.png",
    "64": "./gen-assets/icon64.plasmo.png",
    "128": "./gen-assets/icon128.plasmo.png"
  },
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html",
    "default_title": "CryptoTrack Card"
  },
  "version": "0.1.0",
  "name": "CryptoTrack - MetaMask Card sync",
  "description": "Parse MetaMask Card transaction HTML for debugging.",
  "background": {
    "service_worker": "./static/background/index.ts"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://portfolio.metamask.io/*",
        "https://card.metamask.io/*"
      ],
      "js": [
        "../src/content.ts"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://portfolio.metamask.io/*",
    "https://card.metamask.io/*",
    "http://localhost:4001/*"
  ]
}

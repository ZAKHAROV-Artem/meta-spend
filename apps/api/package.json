{
  "name": "@crypto-tracker/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "pnpm --filter @crypto-tracker/db build && pnpm --filter @crypto-tracker/shared build && nest start --watch",
    "start": "node dist/main",
    "test": "pnpm --filter @crypto-tracker/db build && pnpm --filter @crypto-tracker/shared build && node --test --require ts-node/register --require tsconfig-paths/register src/card-transactions/card-transactions.service.spec.ts src/transactions/card-merchant-auto-categorize.spec.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:reset": "pnpm --filter @crypto-tracker/db run db:reset",
    "db:migrate": "pnpm --filter @crypto-tracker/db run db:migrate",
    "db:seed": "pnpm --filter @crypto-tracker/db run db:seed",
    "db:studio": "pnpm --filter @crypto-tracker/db run studio"
  },
  "dependencies": {
    "@crypto-tracker/db": "workspace:*",
    "@crypto-tracker/shared": "workspace:*",
    "@nestjs/common": "^11.0.5",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.5",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.0.5",
    "@prisma/client": "^6.2.1",
    "@supabase/supabase-js": "^2.105.4",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fastify": "^5.2.1",
    "openai": "^6.36.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "siwe": "^2.3.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.2",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.7",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
